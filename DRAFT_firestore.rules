rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Catch-All Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Lead validation helper (Pillar 2 - Anti-Update-Gap)
    function isValidLead(data) {
      return data.keys().hasAll([
        'nombres', 'apellidos', 'email', 'telefono', 'tipoDocumento', 
        'numeroDocumento', 'mensaje', 'politicaTerminos', 'politicaPublicidad', 
        'politicaPerfilamiento', 'timestamp', 'status', 'origen', 'dispositivo', 'loteInteres'
      ])
      && data.keys().size() == 15
      && data.nombres is string && data.nombres.size() > 0 && data.nombres.size() <= 200
      && data.apellidos is string && data.apellidos.size() > 0 && data.apellidos.size() <= 200
      && data.email is string && data.email.size() > 0 && data.email.size() <= 300
      && data.telefono is string && data.telefono.size() > 0 && data.telefono.size() <= 100
      && data.tipoDocumento is string && data.tipoDocumento.size() > 0 && data.tipoDocumento.size() <= 50
      && data.numeroDocumento is string && data.numeroDocumento.size() > 0 && data.numeroDocumento.size() <= 100
      && data.mensaje is string && data.mensaje.size() <= 4000
      && data.politicaTerminos is bool
      && data.politicaPublicidad is bool
      && data.politicaPerfilamiento is bool
      && data.timestamp is string && data.timestamp.size() <= 100
      && data.status is string && data.status in ['Nuevo', 'Contactado', 'En Progreso', 'Cerrado Ganado']
      && data.origen is string && data.origen.size() <= 200
      && data.dispositivo is string && data.dispositivo.size() <= 200
      && (data.loteInteres == null || (data.loteInteres is string && data.loteInteres.size() <= 200));
    }

    // Settings / SiteImages validation helper
    function isValidSetting(data, settingId) {
      return (
        // Case 1: Individual setting documents (value, updatedAt)
        (data.keys().hasAll(['value', 'updatedAt']) && data.keys().size() == 2
         && data.value is string && data.value.size() <= 2000000 
         && data.updatedAt is string && data.updatedAt.size() <= 100)
        ||
        // Case 2: Unified 'images' fallback document representation
        (settingId == 'images' && data.keys().size() <= 7
         && (!('heroBanner' in data) || (data.heroBanner is string && data.heroBanner.size() <= 2000000))
         && (!('mapPlan' in data) || (data.mapPlan is string && data.mapPlan.size() <= 2000000))
         && (!('testimonialsFamily' in data) || (data.testimonialsFamily is string && data.testimonialsFamily.size() <= 2000000))
         && (!('related1Huacho' in data) || (data.related1Huacho is string && data.related1Huacho.size() <= 2000000))
         && (!('related2Planicie' in data) || (data.related2Planicie is string && data.related2Planicie.size() <= 2000000))
         && (!('related3SantaClara' in data) || (data.related3SantaClara is string && data.related3SantaClara.size() <= 2000000))
        )
      );
    }

    // 2. Leads Collection Matches
    match /leads/{leadId} {
      allow get: if isValidId(leadId);
      allow list: if true; // Listing permitted for unauthenticated admin, but queries can filter
      
      // Public submissions of leads
      allow create: if isValidId(leadId) 
                    && isValidLead(incoming()) 
                    && incoming().status == 'Nuevo';
      
      // Leads update: only status can change in the CRM (Pillar 4 - Tiered Identity logic)
      allow update: if isValidId(leadId) 
                    && isValidLead(incoming()) 
                    && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      
      // Leads deletion from CRM panel
      allow delete: if isValidId(leadId);
    }

    // 3. Settings Collection Matches
    match /settings/{settingId} {
      allow get: if isValidId(settingId);
      allow list: if true; 
      
      // Update or create site graphics configurations
      allow create, update: if isValidId(settingId) 
                            && isValidSetting(incoming(), settingId);
                            
      allow delete: if false; // Deletion is strictly prohibited to preserve site stability
    }
  }
}
